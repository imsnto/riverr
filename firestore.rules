
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
   
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isSpaceAdmin(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
      get(/databases/$(database)/documents/spaces/$(spaceId)).data.members[request.auth.uid].role == 'Admin';
    }
    
    function isExistInSpace(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
      get(/databases/$(database)/documents/spaces/$(spaceId)).data.members[request.auth.uid] != null ;
    }

    function hasAccessToConversation(conversationId) {
      // A user has access to a conversation if they have access to the space the conversation's hub is in.
      let conversationDoc = get(/databases/$(database)/documents/conversations/$(conversationId));
      let hubDoc = get(/databases/$(database)/documents/hubs/$(conversationDoc.data.hubId));
      let spaceId = hubDoc.data.spaceId;
      return isExistInSpace(spaceId);
    }
  
    
    match /users/{userId} {
      allow update, delete: if isAuthenticated() && isOwner(userId);
      allow create, read: if isAuthenticated();
    }
    
    match /spaces/{spaceId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(spaceId);
      allow create: if isAuthenticated();
      allow list: if isAuthenticated() && 
        resource.data.members[request.auth.uid].role in ['Admin', 'Member'];
    }
    
    match /hubs/{hubId} {
      allow read, update, list, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isSpaceAdmin(request.resource.data.spaceId);
    }
    
    match /projects/{projectId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.space_id);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.space_id);
      allow list: if isAuthenticated();
    }
    
    match /tasks/{taskId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.spaceId);
      allow list: if isAuthenticated();
    }
    
    match /time_entries/{entryId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.spaceId);
      allow list: if isAuthenticated();
    }
    
    match /documents/{documentId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.spaceId);
      allow list: if isAuthenticated();
    }
    
    match /channels/{entryId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.space_id);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.space_id);
      allow list: if isAuthenticated();
    }
    
    match /invites/{inviteId} {
      allow read, write: if isAuthenticated();
    }
    
    match /task_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /phase_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /read_states/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /job_flow_tasks/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /job_flow_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /jobs/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /messages/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /slack_meeting_logs/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /bots/{botId} {
      // Read access is public so the widget can fetch its config.
      // In a production app with sensitive bot data, this should be a server-side read.
      allow read: if true;
      allow create: if isAuthenticated() && (
          let hubId = request.resource.data.hubId;
          let spaceId = get(/databases/$(database)/documents/hubs/$(hubId)).data.spaceId;
          isExistInSpace(spaceId)
      );
      allow update, delete: if isAuthenticated() && (
          let hubId = resource.data.hubId;
          let spaceId = get(/databases/$(database)/documents/hubs/$(hubId)).data.spaceId;
          isExistInSpace(spaceId)
      );
    }
    
    match /contacts/{contactId} {
      allow create, get: if true;
      allow update, list: if isAuthenticated();
    }
    
    match /visitors/{visitorId} {
        allow read, write: if true;
    }
    
    match /conversations/{conversationId} {
      allow read, update, delete: if isAuthenticated() && hasAccessToConversation(conversationId);
      allow create: if true; // Allow anonymous creation via widget
    }
    
    match /chat_messages/{messageId} {
      allow read, update, delete: if isAuthenticated() && hasAccessToConversation(resource.data.conversationId);
      allow create: if true; // Allow anonymous creation via widget
    }

    match /help_centers/{hcId} {
      allow create: if isAuthenticated() && (
          let hubId = request.resource.data.hubId;
          let spaceId = get(/databases/$(database)/documents/hubs/$(hubId)).data.spaceId;
          isExistInSpace(spaceId)
      );
      allow read, update, delete: if isAuthenticated() && (
          let hubId = resource.data.hubId;
          let spaceId = get(/databases/$(database)/documents/hubs/$(hubId)).data.spaceId;
          isExistInSpace(spaceId)
      );
    }
    match /help_center_collections/{hccId} {
       allow create: if isAuthenticated() && (
          let helpCenter = get(/databases/$(database)/documents/help_centers/$(request.resource.data.helpCenterId));
          let hubId = helpCenter.data.hubId;
          let spaceId = get(/databases/$(database)/documents/hubs/$(hubId)).data.spaceId;
          isExistInSpace(spaceId)
      );
       allow read, update, delete: if isAuthenticated() && (
          let helpCenter = get(/databases/$(database)/documents/help_centers/$(resource.data.helpCenterId));
          let hubId = helpCenter.data.hubId;
          let spaceId = get(/databases/$(database)/documents/hubs/$(hubId)).data.spaceId;
          isExistInSpace(spaceId)
      );
    }
    match /help_center_articles/{hcaId} {
      allow create: if isAuthenticated() && (
          let hubId = request.resource.data.hubId;
          let spaceId = get(/databases/$(database)/documents/hubs/$(hubId)).data.spaceId;
          isExistInSpace(spaceId)
      );
       allow read, update, delete: if isAuthenticated() && (
          let hubId = resource.data.hubId;
          let spaceId = get(/databases/$(database)/documents/hubs/$(hubId)).data.spaceId;
          isExistInSpace(spaceId)
      );
    }
  }
}
