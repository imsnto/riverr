
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
   
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isSpaceAdmin(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
      get(/databases/$(database)/documents/spaces/$(spaceId)).data.members[request.auth.uid].role == 'Admin';
    }
    
    function isExistInSpace(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
      get(/databases/$(database)/documents/spaces/$(spaceId)).data.members[request.auth.uid] != null ;
    }
  
    
    match /users/{userId} {
      allow update, delete: if isAuthenticated() && isOwner(userId);
      allow create, read: if isAuthenticated();
    }
    
    match /spaces/{spaceId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(spaceId);
      allow create: if isAuthenticated();
      allow list: if isAuthenticated() && 
        resource.data.members[request.auth.uid].role in ['Admin', 'Member'];
    }
    
    match /hubs/{hubId} {
      allow read, update, list, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isSpaceAdmin(request.resource.data.spaceId);
    }
    
    match /projects/{projectId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.space_id);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.space_id);
      allow list: if isAuthenticated();
    }
    
    match /tasks/{taskId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.spaceId);
      allow list: if isAuthenticated();
    }
    
    match /time_entries/{entryId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.spaceId);
      allow list: if isAuthenticated();
    }
    
    match /documents/{documentId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.spaceId);
      allow list: if isAuthenticated();
    }
    
    match /channels/{entryId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.space_id);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.space_id);
      allow list: if isAuthenticated();
    }
    
    match /invites/{inviteId} {
      allow read, write: if isAuthenticated();
    }
    
    match /task_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /phase_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /read_states/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /job_flow_tasks/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /job_flow_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /jobs/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /messages/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /slack_meeting_logs/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /bots/{botId} {
      allow read, write: if isAuthenticated();
    }
    
    match /chat_contacts/{contactId} {
      allow read, write: if isAuthenticated();
    }
    
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated();
    }
    
    match /chat_messages/{messageId} {
      allow read, write: if isAuthenticated();
    }
  }
}
