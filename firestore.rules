
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
   
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isSpaceAdmin(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
        get(/databases/$(database)/documents/spaces/$(spaceId)).data.members[request.auth.uid].role == 'Admin';
    }
    
    function isExistInSpace(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
        get(/databases/$(database)/documents/spaces/$(spaceId)).data.members[request.auth.uid] != null;
    }

    function getHubRole(spaceId, hubId) {
      let space = get(/databases/$(database)/documents/spaces/$(spaceId));
      let member = space.data.members[request.auth.uid];
      if (member == null) {
        return null;
      }
      if (member.role == 'Admin') {
        return 'Hub Admin';
      }
      return member.hubAccess[hubId];
    }
    
    function isHubMember(spaceId, hubId) {
      let role = getHubRole(spaceId, hubId);
      return role == 'Member' || role == 'Hub Admin';
    }

    function isHubAdmin(spaceId, hubId) {
      let role = getHubRole(spaceId, hubId);
      return role == 'Hub Admin';
    }

    function hasAccessToConversation(conversationId) {
      let conversationDoc = get(/databases/$(database)/documents/conversations/$(conversationId));
      let hubId = conversationDoc.data.hubId;
      let hubDoc = get(/databases/$(database)/documents/hubs/$(hubId));
      let spaceId = hubDoc.data.spaceId;
      return isHubMember(spaceId, hubId);
    }
  
    match /users/{userId} {
      allow update, delete: if isAuthenticated() && isOwner(userId);
      allow create, read: if isAuthenticated();
    }
    
    match /spaces/{spaceId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(spaceId);
      allow create: if isAuthenticated();
      allow list: if isAuthenticated();
        
      match /commsNumbers/{numberId} {
        allow read: if isAuthenticated() && isExistInSpace(spaceId);
      }
    }
    
    match /hubs/{hubId} {
      allow read, update, list, delete: if isAuthenticated() && isHubMember(resource.data.spaceId, hubId);
      allow create: if isAuthenticated() && isSpaceAdmin(request.resource.data.spaceId);
    }
    
    match /projects/{projectId} {
      allow read, update, delete: if isAuthenticated() && isHubMember(resource.data.spaceId, resource.data.hubId);
      allow create: if isAuthenticated() && isHubMember(request.resource.data.spaceId, request.resource.data.hubId);
      allow list: if isAuthenticated();
    }
    
    match /tasks/{taskId} {
      allow read, update, delete: if isAuthenticated() && isHubMember(resource.data.spaceId, resource.data.hubId);
      allow create: if isAuthenticated() && isHubMember(request.resource.data.spaceId, request.resource.data.hubId);
      allow list: if isAuthenticated();
    }
    
    match /tickets/{ticketId} {
      allow read, update, delete: if isAuthenticated() && isHubMember(resource.data.spaceId, resource.data.hubId);
      allow create: if isAuthenticated() && isHubMember(request.resource.data.spaceId, request.resource.data.hubId);
      allow list: if isAuthenticated();
    }

    match /deals/{dealId} {
      allow read, update, delete: if isAuthenticated() && isHubMember(resource.data.spaceId, resource.data.hubId);
      allow create: if isAuthenticated() && isHubMember(request.resource.data.spaceId, request.resource.data.hubId);
      allow list: if isAuthenticated();
    }
    
    match /time_entries/{entryId} {
      allow read, update, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.spaceId);
      allow list: if isAuthenticated();
    }
    
    match /documents/{documentId} {
      allow read, update, delete: if isAuthenticated() && isHubMember(resource.data.spaceId, resource.data.hubId);
      allow create: if isAuthenticated() && isHubMember(request.resource.data.spaceId, request.resource.data.hubId);
      allow list: if isAuthenticated();
    }
    
    match /channels/{entryId} {
      allow read, update, delete: if isAuthenticated() && isHubMember(resource.data.spaceId, resource.data.hubId);
      allow create: if isAuthenticated() && isHubMember(request.resource.data.spaceId, request.resource.data.hubId);
      allow list: if isAuthenticated();
    }
    
    match /invites/{inviteId} {
      allow read, write: if isAuthenticated();
    }
    
    match /task_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /phase_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /job_flow_tasks/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /job_flow_templates/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /jobs/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /messages/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /slack_meeting_logs/{entryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /bots/{botId} {
      allow read: if true;
      allow create: if isAuthenticated() && isHubAdmin(get(/databases/$(database)/documents/hubs/$(request.resource.data.hubId)).data.spaceId, request.resource.data.hubId);
      allow update, delete: if isAuthenticated() && isHubAdmin(get(/databases/$(database)/documents/hubs/$(resource.data.hubId)).data.spaceId, resource.data.hubId);
    }
    
    match /contacts/{contactId} {
      allow read: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow create: if isAuthenticated() && isExistInSpace(request.resource.data.spaceId);
      allow update, delete: if isAuthenticated() && isExistInSpace(resource.data.spaceId);
      allow list: if isAuthenticated();
      match /events/{eventId} {
        allow read, write: if isAuthenticated() && isExistInSpace(get(/databases/$(database)/documents/contacts/$(contactId)).data.spaceId);
      }
    }
    
    match /visitors/{visitorId} {
        allow read, write: if true;
    }
    
    match /conversations/{conversationId} {
      allow read: if true; 
      allow create: if true 
        && request.resource.data.channel in ['webchat', 'sms', 'voice'];
      allow update: if isAuthenticated() && hasAccessToConversation(conversationId)
        || (request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastVisitorSeenAt', 'lastVisitorActiveAt', 'visitorName', 'visitorEmail', 'visitorPhone']));
      allow delete: if isAuthenticated() && hasAccessToConversation(conversationId);
    }
    
    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated() && hasAccessToConversation(resource.data.conversationId);
    }

    match /help_centers/{hcId} {
      allow create: if isAuthenticated() && isHubAdmin(get(/databases/$(database)/documents/hubs/$(request.resource.data.hubId)).data.spaceId, request.resource.data.hubId);
      allow read, update, delete: if isAuthenticated() && isHubMember(get(/databases/$(database)/documents/hubs/$(request.resource.data.hubId)).data.spaceId, resource.data.hubId);
    }
    match /help_center_collections/{hccId} {
       allow create: if isAuthenticated() && isHubAdmin(get(/databases/$(database)/documents/hubs/$(request.resource.data.hubId)).data.spaceId, request.resource.data.hubId);
       allow read, update, delete: if isAuthenticated() && isHubMember(get(/databases/$(database)/documents/hubs/$(resource.data.hubId)).data.spaceId, resource.data.hubId);
    }
    match /help_center_articles/{hcaId} {
      allow create: if isAuthenticated() && isHubAdmin(get(/databases/$(database)/documents/hubs/$(request.resource.data.hubId)).data.spaceId, request.resource.data.hubId);
       allow read, update, delete: if isAuthenticated() && isHubMember(get(/databases/$(database)/documents/hubs/$(resource.data.hubId)).data.spaceId, resource.data.hubId);
    }

    match /phone_channel_lookups/{lookupId} {
      allow read: if true; 
      allow write: if false; // System only (Cloud Functions)
    }

    match /provider_call_lookups/{sid} {
      allow read: if true;
      allow write: if false; // System only
    }

    match /twilio_subaccount_secrets/{sid} {
      allow read, write: if false; // Admin SDK only
    }

    match /providers/{providerId} {
      allow read: if false; // Admin SDK only (sensitive secrets)
      allow write: if false; // Manual/Admin setup
    }
  }
}
