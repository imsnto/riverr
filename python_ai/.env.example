# Riverr AI Service Configuration

# Firebase
FIREBASE_PROJECT_ID=riverr-prod
FIRESTORE_CREDENTIALS_PATH=./serviceAccountKey.json

# Vertex AI
VERTEX_PROJECT_ID=riverr-prod
VERTEX_REGION=us-central1
VECTOR_SEARCH_INDEX_NAME=articles-index
VECTOR_SEARCH_ENDPOINT=

# Gemini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# Service
PORT=8000
DEBUG=False
SERVICE_URL=http://localhost:8000

# Timeouts
VECTOR_SEARCH_TIMEOUT=5
LLM_GENERATION_TIMEOUT=10

# Performance
VECTOR_SEARCH_POOL_SIZE=5
BOT_CONFIG_CACHE_TTL=3600
